{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-api",
      "command": "dotnet",
      "args": [
        "build",
        "src/NewShowsInTown.Api/NewShowsInTown.Api.csproj"
      ],
      "type": "process"
    },
    {
      "label": "build-web",
      "command": "dotnet",
      "args": [
        "build",
        "src/NewShowsInTown.Web/NewShowsInTown.Web.csproj"
      ],
      "type": "process"
    },
    {
      "label": "run-web",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/NewShowsInTown.Web/NewShowsInTown.Web.csproj"
      ],
      "type": "process",
      "isBackground": true
    },
    {
      "label": "run-scraper-salle-andre-mathieu",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "src/NewShowsInTown.Scraper.SalleAndreMathieu",
        "src/NewShowsInTown.Scraper.SalleAndreMathieu/main.py"
      ],
      "type": "process",
      "problemMatcher": [
        "$python"
      ]
    }
  ]
}