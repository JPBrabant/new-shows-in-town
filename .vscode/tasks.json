{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-api",
      "command": "dotnet",
      "args": [
        "build",
        "src/NewShowsInTown.Api/NewShowsInTown.Api.csproj"
      ],
      "type": "process"
    },
    {
      "label": "build-web",
      "command": "dotnet",
      "args": [
        "build",
        "src/NewShowsInTown.Web/NewShowsInTown.Web.csproj"
      ],
      "type": "process"
    },
    {
      "label": "run-web",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/NewShowsInTown.Web/NewShowsInTown.Web.csproj"
      ],
      "type": "process",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "run-scraper-salle-andre-mathieu",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "src/NewShowsInTown.Scraper.SalleAndreMathieu",
        "src/NewShowsInTown.Scraper.SalleAndreMathieu/main.py"
      ],
      "type": "process",
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "export-requirements",
      "command": "uv",
      "args": [
        "export",
        "--project",
        "src/NewShowsInTown.Scraper.SalleAndreMathieu",
        "--format",
        "requirements-txt",
        "--output-file",
        "src/NewShowsInTown.Scraper.SalleAndreMathieu/requirements.txt"
      ],
      "type": "process",
      "problemMatcher": []
    },
    {
      "label": "run-function-salle-andre-mathieu",
      "dependsOn": ["export-requirements"],
      "command": "func",
      "args": [
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/NewShowsInTown.Scraper.SalleAndreMathieu"
      },
      "type": "process",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}