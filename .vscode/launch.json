{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": [
        "run",
        "--project",
        "src/NewShowsInTown.Api/NewShowsInTown.Api.csproj",
        "--launch-profile", "https"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "uriFormat": "https://localhost:5000",
        "pattern": "Now listening on"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["API"],
      "preLaunchTask": "run-web",
      "stopAll": true
    }
  ]
}