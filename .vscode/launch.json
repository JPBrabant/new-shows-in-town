{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/NewShowsInTown.Api/bin/Debug/net10.0/NewShowsInTown.Api.dll",
      "cwd": "${workspaceFolder}/src/NewShowsInTown.Api",
      "preLaunchTask": "build-api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:7001"
      }
    },
    {
      "name": "Web (browser)",
      "type": "msedge",
      "request": "launch",
      "url": "https://localhost:5000",
      "webRoot": "${workspaceFolder}/src/NewShowsInTown.Web"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["API", "Web (browser)"],
      "preLaunchTask": "run-web",
      "stopAll": true
    }
  ]
}