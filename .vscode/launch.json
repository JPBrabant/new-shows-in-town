{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/NewShowsInTown.Api/bin/Debug/net10.0/NewShowsInTown.Api.dll",
      "cwd": "${workspaceFolder}/src/NewShowsInTown.Api",
      "preLaunchTask": "build-api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "uriFormat": "https://localhost:5000",
        "pattern": "Now listening on"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["API"],
      "preLaunchTask": "run-web",
      "stopAll": true
    }
  ]
}